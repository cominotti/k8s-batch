<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{40} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Default / remote-partitioning: suppress per-chunk SQL (batch) and consumer
         group rebalancing noise (kafka) to keep production logs readable -->
    <springProfile name="default | remote-partitioning">
        <logger name="com.cominotti.k8sbatch" level="INFO"/>
        <logger name="org.springframework.batch" level="WARN"/>
        <logger name="org.springframework.integration" level="WARN"/>
        <logger name="org.apache.kafka" level="WARN"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Standalone: DEBUG on the standalone subpackage for TaskExecutorPartitionHandler
         thread diagnostics (partition execution, thread pool activity) -->
    <springProfile name="standalone">
        <logger name="com.cominotti.k8sbatch" level="INFO"/>
        <logger name="com.cominotti.k8sbatch.batch.standalone" level="DEBUG"/>
        <logger name="org.springframework.batch" level="WARN"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Integration test -->
    <springProfile name="integration-test">
        <logger name="com.cominotti.k8sbatch" level="DEBUG"/>
        <logger name="org.springframework.batch" level="DEBUG"/>
        <logger name="org.testcontainers" level="INFO"/>
        <logger name="org.apache.kafka" level="WARN"/>
        <logger name="org.springframework.integration" level="INFO"/>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
