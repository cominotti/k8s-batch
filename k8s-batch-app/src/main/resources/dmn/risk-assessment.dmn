<?xml version="1.0" encoding="UTF-8"?>
<!--
  SPDX-License-Identifier: Apache-2.0

  DMN decision model for risk scoring and compliance flagging.
  Evaluated after the DMN adapter computes exchange rate and USD conversion in Java.

  Thresholds match EnrichmentRuleConstants.DEFAULTS:
    - MEDIUM risk >= 1000 USD, HIGH risk >= 10000 USD
    - Compliance review required for HIGH risk OR amountUsd >= 50000

  Input: amountUsd (number) — computed by DmnTransactionRulesEvaluator
  Outputs: Risk Score (string: LOW/MEDIUM/HIGH), Compliance Review (boolean)
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20230324/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20230324/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:feel="https://www.omg.org/spec/DMN/20230324/FEEL/"
             id="risk_assessment"
             name="Risk Assessment"
             namespace="https://cominotti.com/k8s-batch/rules-poc/risk-assessment"
             expressionLanguage="https://www.omg.org/spec/DMN/20230324/FEEL/"
             typeLanguage="https://www.omg.org/spec/DMN/20230324/FEEL/">

    <!-- Input Data -->
    <inputData id="input_amountUsd" name="amountUsd">
        <variable id="var_amountUsd" name="amountUsd" typeRef="number"/>
    </inputData>

    <!-- Decision 1: Risk Score -->
    <decision id="decision_riskScore" name="Risk Score">
        <variable id="var_riskScore" name="Risk Score" typeRef="string"/>
        <informationRequirement id="ir_riskScore_amountUsd">
            <requiredInput href="#input_amountUsd"/>
        </informationRequirement>
        <decisionTable id="dt_riskScore" hitPolicy="UNIQUE" outputLabel="Risk Score">
            <input id="dt_riskScore_input">
                <inputExpression id="dt_riskScore_inputExpr" typeRef="number">
                    <text>amountUsd</text>
                </inputExpression>
            </input>
            <output id="dt_riskScore_output" typeRef="string"/>
            <rule id="dt_riskScore_rule1">
                <inputEntry id="dt_riskScore_ie1">
                    <text>&lt; 1000</text>
                </inputEntry>
                <outputEntry id="dt_riskScore_oe1">
                    <text>"LOW"</text>
                </outputEntry>
            </rule>
            <rule id="dt_riskScore_rule2">
                <inputEntry id="dt_riskScore_ie2">
                    <text>[1000..10000)</text>
                </inputEntry>
                <outputEntry id="dt_riskScore_oe2">
                    <text>"MEDIUM"</text>
                </outputEntry>
            </rule>
            <rule id="dt_riskScore_rule3">
                <inputEntry id="dt_riskScore_ie3">
                    <text>&gt;= 10000</text>
                </inputEntry>
                <outputEntry id="dt_riskScore_oe3">
                    <text>"HIGH"</text>
                </outputEntry>
            </rule>
        </decisionTable>
    </decision>

    <!-- Decision 2: Compliance Review (depends on Risk Score + amountUsd) -->
    <decision id="decision_complianceReview" name="Compliance Review">
        <variable id="var_complianceReview" name="Compliance Review" typeRef="boolean"/>
        <informationRequirement id="ir_compliance_riskScore">
            <requiredDecision href="#decision_riskScore"/>
        </informationRequirement>
        <informationRequirement id="ir_compliance_amountUsd">
            <requiredInput href="#input_amountUsd"/>
        </informationRequirement>
        <decisionTable id="dt_compliance" hitPolicy="FIRST" outputLabel="Compliance Review">
            <input id="dt_compliance_input1">
                <inputExpression id="dt_compliance_inputExpr1" typeRef="string">
                    <text>Risk Score</text>
                </inputExpression>
            </input>
            <input id="dt_compliance_input2">
                <inputExpression id="dt_compliance_inputExpr2" typeRef="number">
                    <text>amountUsd</text>
                </inputExpression>
            </input>
            <output id="dt_compliance_output" typeRef="boolean"/>
            <rule id="dt_compliance_rule1">
                <inputEntry id="dt_compliance_ie1">
                    <text>"HIGH"</text>
                </inputEntry>
                <inputEntry id="dt_compliance_ie2">
                    <text>-</text>
                </inputEntry>
                <outputEntry id="dt_compliance_oe1">
                    <text>true</text>
                </outputEntry>
            </rule>
            <rule id="dt_compliance_rule2">
                <inputEntry id="dt_compliance_ie3">
                    <text>-</text>
                </inputEntry>
                <inputEntry id="dt_compliance_ie4">
                    <text>&gt;= 50000</text>
                </inputEntry>
                <outputEntry id="dt_compliance_oe2">
                    <text>true</text>
                </outputEntry>
            </rule>
            <rule id="dt_compliance_rule3">
                <inputEntry id="dt_compliance_ie5">
                    <text>-</text>
                </inputEntry>
                <inputEntry id="dt_compliance_ie6">
                    <text>-</text>
                </inputEntry>
                <outputEntry id="dt_compliance_oe3">
                    <text>false</text>
                </outputEntry>
            </rule>
        </decisionTable>
    </decision>

</definitions>
