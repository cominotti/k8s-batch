package com.cominotti.k8sbatch.batch.rulespoc.rules;

import com.cominotti.k8sbatch.batch.rulespoc.adapters.evaluatingrules.TransactionFact;
import com.cominotti.k8sbatch.batch.rulespoc.domain.EnrichmentRuleConstants;
import com.cominotti.k8sbatch.batch.rulespoc.domain.RiskScore;

// Injected by DroolsTransactionRulesEvaluator via session.setGlobal() — single source of truth
// for exchange rates, risk thresholds, and compliance rules (shared with the EVRete adapter).
global EnrichmentRuleConstants ruleConstants;

// ── Exchange Rate Lookup ──────────────────────────────────────────────────────
// Delegates to ruleConstants.rateFor() which provides exchange rates for known currencies
// and a default rate for unknown ones — replacing the previous per-currency rules.

rule "Exchange Rate Lookup"
    no-loop
    salience 100
    when
        $tx : TransactionFact( exchangeRate == null )
    then
        $tx.setExchangeRate(ruleConstants.rateFor($tx.getCurrency()));
        update($tx);
end

// ── USD Conversion ────────────────────────────────────────────────────────────
// Computes amountUsd once the exchange rate is set.

rule "Convert to USD"
    no-loop
    salience 80
    when
        $tx : TransactionFact( exchangeRate != null, amountUsd == null )
    then
        $tx.setAmountUsd($tx.getAmount().multiply($tx.getExchangeRate()));
        update($tx);
end

// ── Risk Score Assignment ─────────────────────────────────────────────────────
// Delegates to ruleConstants.riskScoreFor() which uses BigDecimal.compareTo() for
// precision-safe threshold comparisons.

rule "Risk Score Assignment"
    no-loop
    salience 70
    when
        $tx : TransactionFact( amountUsd != null, riskScore == null )
    then
        $tx.setRiskScore(ruleConstants.riskScoreFor($tx.getAmountUsd()));
        update($tx);
end

// ── Compliance Flag ───────────────────────────────────────────────────────────
// The when clause guards on riskScore being set and compliance not already flagged.
// The actual business decision is in the then block via ruleConstants.requiresComplianceReview().

rule "Compliance Flag"
    no-loop
    salience 60
    when
        $tx : TransactionFact( riskScore != null, complianceFlag == false )
    then
        if (ruleConstants.requiresComplianceReview($tx.getRiskScore(), $tx.getAmountUsd())) {
            $tx.setComplianceFlag(true);
            update($tx);
        }
end
