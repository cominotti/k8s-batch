<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Hibernate 7.x SEQUENCE emulation on MySQL creates one table per @SequenceGenerator.
         Each table has a single next_val column tracking the high watermark for the pooled-lo
         optimizer (allocationSize=50). With ddl-auto=validate, Hibernate will not create these
         tables automatically, so Liquibase must provide them. -->
    <changeSet id="006-create-hibernate-sequences" author="cominotti">
        <createTable tableName="customer_sequence">
            <column name="next_val" type="bigint"/>
        </createTable>
        <insert tableName="customer_sequence">
            <column name="next_val" value="1"/>
        </insert>

        <createTable tableName="account_sequence">
            <column name="next_val" type="bigint"/>
        </createTable>
        <insert tableName="account_sequence">
            <column name="next_val" value="1"/>
        </insert>
    </changeSet>

</databaseChangeLog>
